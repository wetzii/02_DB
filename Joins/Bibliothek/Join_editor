--12. Geben Sie alle Buchtitel mit Autoren Vor und Nachnamen aus, bei denen im Buchtitel
--das Wort „und“ enthalten ist.
Select Buch.bTitle, Autor.aVorname, Autor.aNachname from Buch
LEft Join Autor on Autor.AID is Buch.aID
Where Buch.bTitle like '%und%';

